# Endpoint instancji Grafany, którą testujesz (podmień albo pobierz z terraform output)
$GrafanaUrl = "https://<twoja-instancja>.grafana.azure.com"
# np.: $GrafanaUrl = "https://$(terraform output -raw grafana_endpoint)"

$Headers = @{ Authorization = "Bearer $env:GRAFANA_AUTH" }

# Pomocnik: pokazuje status/body przy błędzie zamiast rzucać nieczytelny wyjątek
function Invoke-GrafanaApi {
    param([string]$Method, [string]$Path, $Body)
    try {
        $params = @{ Uri = "$GrafanaUrl$Path"; Headers = $Headers; Method = $Method }
        if ($Body) { $params.Body = ($Body | ConvertTo-Json); $params.ContentType = 'application/json' }
        Invoke-RestMethod @params
    }
    catch {
        Write-Host "FAIL $Method $Path -> $($_.Exception.Response.StatusCode.value__) $($_.Exception.Response.StatusDescription)"
        if ($_.ErrorDetails.Message) { Write-Host $_.ErrorDetails.Message }
    }
}

# 1. Test logowania — działa dla KAŻDEJ roli (Viewer+), samo potwierdza że token jest OK
